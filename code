C<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MonitorX Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    body{
      background:radial-gradient(circle at top left,#312e81,#0f172a 55%,#020617);
      color:white;
      font-family:Arial,sans-serif;
    }

    .sidebar{
      min-height:100vh;
      background:rgba(30,41,59,0.72);
      backdrop-filter:blur(16px);
      border-right:1px solid rgba(255,255,255,0.08);
      padding:20px 10px;
      box-shadow:0 0 30px rgba(99,102,241,0.18);
    }

    .sidebar button{
      width:100%;
      margin-bottom:10px;
      border:none;
      padding:12px;
      border-radius:12px;
      background:rgba(255,255,255,0.03);
      color:#cbd5e1;
      text-align:left;
      transition:all .3s ease;
    }

    .sidebar button:hover,
    .sidebar button.active{
      background:linear-gradient(135deg,#4f46e5,#7c3aed);
      color:#fff;
      box-shadow:0 0 18px rgba(99,102,241,.45);
    }

    .screen{display:none;}
    .screen.active{display:block;}

    .card-box{
      background:rgba(30,41,59,0.75);
      backdrop-filter:blur(14px);
      border:1px solid rgba(255,255,255,0.06);
      border-radius:22px;
      padding:20px;
      box-shadow:0 8px 30px rgba(79,70,229,.18);
    }

    .circle{
      width:120px;
      height:120px;
      border-radius:50%;
      margin:auto;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:bold;
      font-size:22px;
      position:relative;
      box-shadow:0 0 22px rgba(56,189,248,.25);
    }

    .circle::before{
      content:'';
      position:absolute;
      width:82px;
      height:82px;
      background:#1e293b;
      border-radius:50%;
    }

    .circle span{
      position:relative;
      z-index:1;
    }

    .health-big{
      width:180px;
      height:180px;
      font-size:32px;
    }

    table{
      color:white !important;
    }

    .alert-item{
      padding:12px;
      border-radius:14px;
      margin-bottom:10px;
      box-shadow:0 0 18px rgba(255,255,255,0.08);
    }

    .form-control{
      background:#0f172a;
      border:1px solid #334155;
      color:white;
    }

    .form-control:focus{
      background:#0f172a;
      color:white;
      border-color:#6366f1;
      box-shadow:none;
    }
  </style>
</head>
<body>

<div class="container-fluid">
  <div class="row">

    <!-- Sidebar -->
    <div class="col-md-2 sidebar">
      <h3 class="text-center mb-4">MonitorX</h3>

      <button class="nav-btn active" onclick="showScreen('dashboard', this)">Dashboard Overview</button>
      <button class="nav-btn" onclick="showScreen('analytics', this)">Performance Analytics</button>
      <button class="nav-btn" onclick="showScreen('processes', this)">Processes</button>
      <button class="nav-btn" onclick="showScreen('alerts', this)">Alerts</button>
      <button class="nav-btn" onclick="showScreen('health', this)">System Health Score</button>
      <button class="nav-btn" onclick="showScreen('recommendations', this)">Smart Recommendations</button>
      <button class="nav-btn" onclick="showScreen('thresholds', this)">Custom Threshold Alerts</button>
    </div>

    <!-- Main Content -->
    <div class="col-md-10 p-4">

      <!-- Dashboard -->
      <div id="dashboard" class="screen active">
        <h2 class="mb-4">Dashboard Overview</h2>
        <div class="row g-4">
          <div class="col-md-3"><div class="card-box text-center"><div class="circle" style="background:conic-gradient(#ef4444 0 72%,#334155 72% 100%)"><span>72%</span></div><h5 class="mt-3">CPU</h5></div></div>
          <div class="col-md-3"><div class="card-box text-center"><div class="circle" style="background:conic-gradient(#facc15 0 58%,#334155 58% 100%)"><span>58%</span></div><h5 class="mt-3">RAM</h5></div></div>
          <div class="col-md-3"><div class="card-box text-center"><div class="circle" style="background:conic-gradient(#22c55e 0 81%,#334155 81% 100%)"><span>81%</span></div><h5 class="mt-3">Disk</h5></div></div>
          <div class="col-md-3"><div class="card-box text-center"><div class="circle" style="background:conic-gradient(#38bdf8 0 65%,#334155 65% 100%)"><span>65%</span></div><h5 class="mt-3">Network</h5></div></div>
        </div>
      </div>

      <!-- Analytics -->
      <div id="analytics" class="screen">
        <h2 class="mb-4">Performance Analytics</h2>
        <div class="row g-4">
          <div class="col-md-6"><div class="card-box"><h5>CPU Analysis</h5><canvas id="perfChart"></canvas></div></div>
          <div class="col-md-6"><div class="card-box"><h5>RAM Analysis</h5><canvas id="ramChart"></canvas></div></div>
          <div class="col-md-6"><div class="card-box"><h5>Disk Analysis</h5><canvas id="diskChart"></canvas></div></div>
          <div class="col-md-6"><div class="card-box"><h5>Network Analysis</h5><canvas id="networkChart"></canvas></div></div>
        </div>
      </div>

      <!-- Processes -->
      <div id="processes" class="screen">
        <h2 class="mb-4">Running Processes</h2>
        <div class="card-box">
          <table class="table table-dark table-hover">
            <thead>
              <tr><th>PID</th><th>Process</th><th>CPU%</th><th>Memory%</th><th>Status</th></tr>
            </thead>
            <tbody>
              <tr><td>1024</td><td>Chrome.exe</td><td>25%</td><td>18%</td><td>Running</td></tr>
              <tr><td>2048</td><td>VSCode.exe</td><td>15%</td><td>12%</td><td>Running</td></tr>
              <tr><td>3011</td><td>System</td><td>8%</td><td>5%</td><td>Background</td></tr>
              <tr><td>4022</td><td>Discord.exe</td><td>4%</td><td>7%</td><td>Running</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Alerts -->
      <div id="alerts" class="screen">
        <h2 class="mb-4">System Alerts</h2>
        <div class="card-box">
          <div class="alert-item bg-danger">High CPU Usage Detected - 72%</div>
          <div class="alert-item bg-warning text-dark">Disk Space Running Low - 81%</div>
          <div class="alert-item bg-info">Network Spike Observed - 124 Mbps</div>
        </div>
      </div>

      <!-- Health Score -->
      <div id="health" class="screen">
        <h2 class="mb-4">System Health Score</h2>
        <div class="row g-4">
          <div class="col-md-6">
            <div class="card-box text-center">
              <div class="circle health-big" style="background:conic-gradient(#22c55e 0 82%,#334155 82% 100%)">
                <span>82</span>
              </div>
              <h3 class="mt-4">Healthy System</h3>
              <p class="text-secondary">Based on CPU, RAM, Disk, and Network utilization</p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card-box">
              <h4>Health Breakdown</h4>
              <ul class="list-group list-group-flush mt-3">
                <li class="list-group-item bg-transparent text-white">CPU Efficiency: 78%</li>
                <li class="list-group-item bg-transparent text-white">Memory Stability: 84%</li>
                <li class="list-group-item bg-transparent text-white">Disk Health: 80%</li>
                <li class="list-group-item bg-transparent text-white">Network Performance: 86%</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Recommendations -->
      <div id="recommendations" class="screen">
        <h2 class="mb-4">Smart Recommendations</h2>
        <div class="card-box">
          <div class="alert-item bg-warning text-dark">High RAM usage detected. Consider closing unused applications.</div>
          <div class="alert-item bg-info">Network traffic spike observed. Check for active downloads/uploads.</div>
          <div class="alert-item bg-danger">Disk utilization above 80%. Cleanup recommended.</div>
          <div class="alert-item bg-success">CPU performance stable. No optimization needed currently.</div>
        </div>
      </div>

      <!-- Threshold Alerts -->
      <div id="thresholds" class="screen">
        <h2 class="mb-4">Custom Threshold Alerts</h2>

        <div class="row g-4">
          <div class="col-md-6">
            <div class="card-box">
              <h4 class="mb-3">Set Threshold Limits</h4>

              <label>CPU Alert Threshold (%)</label>
              <input type="number" id="cpuThreshold" class="form-control mb-3" value="80">

              <label>RAM Alert Threshold (%)</label>
              <input type="number" id="ramThreshold" class="form-control mb-3" value="75">

              <label>Disk Alert Threshold (%)</label>
              <input type="number" id="diskThreshold" class="form-control mb-3" value="85">

              <label>Network Alert Threshold (Mbps)</label>
              <input type="number" id="networkThreshold" class="form-control mb-3" value="120">

              <button class="btn btn-primary w-100" onclick="checkThresholds()">
                Apply Thresholds
              </button>
            </div>
          </div>

          <div class="col-md-6">
            <div class="card-box">
              <h4 class="mb-3">Threshold Status</h4>
              <div id="thresholdResults"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
function showScreen(id, btn){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');

  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function checkThresholds(){
  const cpu=72, ram=58, disk=81, network=124;

  const cpuT=document.getElementById("cpuThreshold").value;
  const ramT=document.getElementById("ramThreshold").value;
  const diskT=document.getElementById("diskThreshold").value;
  const networkT=document.getElementById("networkThreshold").value;

  let output="";

  output += cpu > cpuT
    ? `<div class="alert-item bg-danger">CPU exceeded threshold (${cpu}% > ${cpuT}%)</div>`
    : `<div class="alert-item bg-success">CPU within threshold</div>`;

  output += ram > ramT
    ? `<div class="alert-item bg-danger">RAM exceeded threshold (${ram}% > ${ramT}%)</div>`
    : `<div class="alert-item bg-success">RAM within threshold</div>`;

  output += disk > diskT
    ? `<div class="alert-item bg-danger">Disk exceeded threshold (${disk}% > ${diskT}%)</div>`
    : `<div class="alert-item bg-success">Disk within threshold</div>`;

  output += network > networkT
    ? `<div class="alert-item bg-danger">Network exceeded threshold (${network} Mbps > ${networkT} Mbps)</div>`
    : `<div class="alert-item bg-success">Network within threshold</div>`;

  document.getElementById("thresholdResults").innerHTML = output;
}

const chartOptions={
  plugins:{legend:{labels:{color:'white'}}},
  scales:{
    x:{ticks:{color:'white'}},
    y:{ticks:{color:'white'}}
  }
};

new Chart(document.getElementById('perfChart'), {
  type:'line',
  data:{
    labels:['Mon','Tue','Wed','Thu','Fri','Sat'],
    datasets:[{label:'CPU Usage %',data:[45,60,55,72,68,58],borderColor:'#38bdf8',tension:0.4}]
  },
  options:chartOptions
});

new Chart(document.getElementById('ramChart'), {
  type:'line',
  data:{
    labels:['Mon','Tue','Wed','Thu','Fri','Sat'],
    datasets:[{label:'RAM Usage %',data:[35,48,52,58,63,55],borderColor:'#2dd4bf',tension:0.4}]
  },
  options:chartOptions
});

new Chart(document.getElementById('diskChart'), {
  type:'bar',
  data:{
    labels:['C','D','E','F'],
    datasets:[{label:'Disk Usage %',data:[81,65,42,55],backgroundColor:'#fb923c'}]
  },
  options:chartOptions
});

new Chart(document.getElementById('networkChart'), {
  type:'line',
  data:{
    labels:['10AM','11AM','12PM','1PM','2PM','3PM'],
    datasets:[{label:'Mbps',data:[90,120,80,140,110,124],borderColor:'#c084fc',tension:0.4}]
  },
  options:chartOptions
});
</script>

</body>
</html>
